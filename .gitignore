# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore JetBrains / IntelliJ / RubyMine IDE files
.idea/
*.iml
.idea/*.xml
# Ignore Ruby version manager files (if you don't want to enforce them)
# .ruby-version

# Ignore macOS system files
.DS_Store

# Ignore localized library testing files
test_song.mp3

# Ignore JavaScript dependencies
/node_modules

# Ignore compiled CSS and JS artifacts
/app/assets/builds/*
!/app/assets/builds/.keep

.kamal/secrets

# Ignore the nested/backup project
/client/

# Ignore Kamal deployment files until we actually use them
/.kamal/
/bin/kamal

/storage/*
!/storage/.keep