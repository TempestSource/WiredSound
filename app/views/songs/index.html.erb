<div class="container mt-4">
  <%= turbo_stream_from "songs" %>
  <%= turbo_stream_from "unrecognized_songs" %>

  <h2>My Library</h2>

  <div class="row" id="songs">
    <% if @recognized_songs.any? %>
      <%= render partial: "songs/song", collection: @recognized_songs, as: :song %>
    <% else %>
      <p class="text-muted text-center py-5" id="no-songs-msg">No recognized songs in your library yet.</p>
    <% end %>
  </div>

  <hr class="my-5">

  <h3 class="text-muted">Unrecognized Files</h3>

  <div class="row" id="unrecognized_songs">
    <%= render partial: "songs/unrecognized_song", collection: @unrecognized_files, as: :song %>
  </div>
</div>