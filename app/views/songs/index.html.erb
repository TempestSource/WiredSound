<div class="container mt-4">
  <h2>My Library</h2>

  <div class="row" id="recognized-songs-list">
    <% if @recognized_songs.any? %>
      <%= render partial: "songs/song", collection: @recognized_songs, as: :song %>
    <% else %>
      <p class="text-muted text-center py-5" id="no-songs-msg">No recognized songs in your library yet.</p>
    <% end %>
  </div>

  <hr class="my-5">

  <h3 class="text-muted">Unrecognized Files</h3>
  <div class="row">
    <% @unrecognized_files.each do |file| %>
      <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-warning h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title text-truncate" title="<%= file.songName %>">
              <%= file.songName %>
            </h5>
            <p class="card-text text-warning small mb-3">
              <i class="bi bi-exclamation-triangle"></i> Local File | Missing Metadata
            </p>

            <div class="mt-auto d-flex gap-2">
              <%= link_to "View Details", song_path(file.songID), class: "btn btn-sm btn-outline-warning flex-grow-1" %>

              <%= link_to "Link", link_song_path(id: 'new', filename: file.songName), class: "btn btn-sm btn-warning" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>