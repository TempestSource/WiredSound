<div class="container mt-4">
  <h2>My Library</h2>

  <div class="row">
    <% if @recognized_songs.any? %>
      <% @recognized_songs.each do |song| %>
        <div class="col-md-4 mb-3">
          <div class="card shadow-sm border-success h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title text-truncate"><%= song.songName %></h5>
              <p class="card-text text-success small mb-3">
                <i class="bi bi-check-circle-fill"></i> On Database
              </p>

              <%= link_to "Song Page", song_path(song), class: "btn btn-outline-primary mt-auto" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted">No recognized songs in your library yet.</p>
    <% end %>
  </div>

  <hr class="my-5">

  <h3 class="text-muted">Unrecognized Files</h3>
  <div class="row">
    <% @unrecognized_files.each do |file| %>
      <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-warning h-100">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title text-truncate"><%= file.songName %></h5>
            <p class="card-text text-warning small mb-3">
              <i class="bi bi-exclamation-triangle"></i> Local File | Missing Metadata
            </p>

            <%= link_to "Link Metadata", link_song_path(id: 'new', filename: file.songName), class: "btn btn-outline-warning mt-auto" %>          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>