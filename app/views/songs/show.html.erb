<h1><%= @song.songName %></h1>
<p><i><%= @song.artist_infos.first&.artistName || "Unknown Artist" %></i></p>

<div class="row">
  <div class="col">
    <p><b>Release Date:</b> <%= @song.album_release&.album_info&.releaseDate || "Unknown" %></p>
    <p><b>Track Number:</b> <%= @song.trackNumber || "Unknown" %></p>
    <p><b>ID:</b> <%= @song.songID %></p>

    <div class="d-flex gap-2 mb-3">
      <%= link_to "Link song", link_song_path(@song.songID), class: "btn btn-primary" %>
      <%= link_to "Back", songs_path, class: "btn btn-secondary" %>
    </div>

    <div class="media-player p-3 border rounded bg-dark mt-3">
      <p class="text-sm text-muted mb-2">
        Previewing: <strong><%= @song.songName %></strong>
      </p>

      <audio controls preload="metadata" class="w-100">
        <source src="<%= play_song_path(@song.songID) %>" type="audio/mpeg">
        Your browser does not support the audio element.
      </audio>
    </div>
  </div>

  <div class="col">
    <% cover_path = @song.album_release&.album_info&.coverPath %>

    <% if cover_path.present? %>
      <img class="card-img-top shadow rounded" src="<%= cover_path %>"
           style="width: 65%; aspect-ratio: 1/1; object-fit: cover;" alt="Album Cover">
    <% else %>
      <div class="placeholder-art">
        <img class="card-img-top" src="<%= asset_path('wave.png') %>"
             style="width: 65%" alt="Audio Waveform">

        <div class="mt-2 text-muted" style="width: 65%; font-size: 0.9rem;">
          <i class="bi bi-info-circle"></i> No official cover art found in the archive.
        </div>
      </div>
    <% end %>

    <p class="mt-3">
      <strong><%= @song.album_release&.album_info&.albumName || "Unknown Album" %></strong>
    </p>
  </div>
</div>

<hr class="mt-5">

<div class="mt-4">
  <%= button_to "Delete Song", song_path(@song), method: :delete,
                data: { turbo_confirm: "Are you sure you want to delete this song from your local storage?" },
                class: "btn btn-outline-danger btn-sm" %>
</div>