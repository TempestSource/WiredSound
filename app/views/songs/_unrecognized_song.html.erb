<%# app/views/songs/_unrecognized_song.html.erb %>
<div id="<%= dom_id(song) %>" class="col-md-4 mb-3">
  <div class="card shadow-sm border-warning h-100">
    <div class="card-body d-flex flex-column">
      <h5 class="card-title text-truncate" title="<%= song.songName %>">
        <%= song.songName %>
      </h5>
      <p class="card-text text-warning small mb-3">
        <i class="bi bi-exclamation-triangle"></i> Local File | Missing Metadata
      </p>

      <div class="mt-auto d-flex gap-2">
        <%= link_to "View Details", song_path(song.songID), class: "btn btn-sm btn-outline-warning flex-grow-1" %>
        <%= link_to "Link", link_song_path(id: 'new', filename: song.songName), class: "btn btn-sm btn-warning" %>
      </div>
    </div>
  </div>
</div>