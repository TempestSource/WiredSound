<%# app/views/songs/_song.html.erb %>
<% album_info = song.album_release&.album_info %>
<%# Check both naming conventions to be safe %>
<% cover_url = album_info&.try(:coverPath) || album_info&.try(:cover_path) %>

<div id="<%= dom_id(song) %>" class="col-md-4 mb-3">
  <div class="card shadow-sm border-success h-100">
    <div class="row g-0 h-100">
      <div class="col-12">
        <div class="card-body d-flex flex-column h-100">
          <h5 class="card-title text-truncate mb-1" title="<%= song.songName %>"><%= song.songName %></h5>
          <p class="card-text small mb-0 text-muted text-truncate">
            <strong>Artist:</strong> <%= song.artist_infos.first&.artistName || "Unknown Artist" %>
          </p>
          <p class="card-text small mb-2 text-muted text-truncate">
            <strong>Album:</strong> <%= song.album_release&.album_info&.albumName || "Unknown Album" %>
          </p>
          <p class="card-text text-success small mb-3">
            <i class="bi bi-check-circle-fill"></i> Database Match
          </p>
          <%= link_to "View Details", song_path(song), class: "btn btn-outline-primary btn-sm mt-auto w-100" %>
        </div>
      </div>
    </div>
  </div>
</div>