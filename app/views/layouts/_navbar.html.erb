<nav class="navbar navbar-expand-lg bg-dark border-bottom border-secondary" data-bs-theme="dark">
  <div class="container-fluid">
    <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
      <%= image_tag "wave.png", height: "30", class: "me-2" %>
      <span class="fw-bold text-success">WiredSound</span>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to "Library", root_path, class: "nav-link" %>
        </li>
        <% sort_labels = { "title" => "Title", "artist" => "Artist", "album" => "Album" } %>
        <% current_sort_label = sort_labels[params[:sort]] || "Sort By" %>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span><%= current_sort_label %></span>
          </a>

          <ul class="dropdown-menu dropdown-menu-dark border-secondary shadow">
            <% sort_labels.each do |key, label| %>
              <li>
                <%= link_to root_path(sort: key, query: params[:query]),
                            class: "dropdown-item d-flex justify-content-between align-items-center #{'active bg-success bg-opacity-25' if params[:sort] == key}" do %>
                  <%= label %>
                  <% if params[:sort] == key %>
                    <i class="bi bi-check-lg text-success"></i>
                  <% end %>
                <% end %>
              </li>
            <% end %>

            <% if params[:sort].present? %>
              <li><hr class="dropdown-divider border-secondary"></li>
              <li>
                <%= link_to "Clear Sort", root_path(query: params[:query]), class: "dropdown-item text-muted small" %>
              </li>
            <% end %>
          </ul>
        </li>
      </ul>

      <%# Search Bar %>
      <%= form_with url: root_path, method: :get, class: "d-flex me-3", local: true do |f| %>
        <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
        <%= f.search_field :query, value: params[:query], class: "form-control me-2 bg-dark text-light border-secondary", placeholder: "Search...", "aria-label": "Search" %>
        <%= f.submit "Search", class: "btn btn-outline-success", name: nil %>
      <% end %>

      <ul class="navbar-nav align-items-center">
        <% if session[:user_id] %>
          <li class="nav-item me-3">
            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
              <i class="bi bi-person-fill me-1"></i> <%= User.find_by(username: session[:user_id])&.username %>
            </span>
          </li>
          <li class="nav-item me-2">
            <%= link_to "Settings", settings_path, class: "nav-link p-0 text-secondary" %>
          </li>
          <li class="nav-item">
            <%= link_to "Log Out", logout_path, data: { turbo_method: :delete }, class: "btn btn-sm btn-outline-danger" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Log In", login_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign Up", signup_path, class: "btn btn-sm btn-success ms-lg-2" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>