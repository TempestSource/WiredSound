<div class="container mt-4">
  <h2>WiredSound Listener Configuration</h2>
  <p class="text-muted">Update the directory the system monitors for new music imports.</p>

  <%= form_with url: settings_path, method: :patch, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :incoming_path, "Monitor Directory Path", class: "form-label" %>
      <%= f.text_field :incoming_path, value: @incoming_path, class: "form-control", placeholder: "/rails/storage/incoming_music" %>
    </div>

    <%= f.submit "Reinitialize Listener", class: "btn btn-primary" %>
  <% end %>

  <div class="mt-5">
    <h4>Listener Status</h4>
    <div class="alert alert-info">
      <strong>Active Path:</strong> <%= @incoming_path %>
    </div>
  </div>
</div>