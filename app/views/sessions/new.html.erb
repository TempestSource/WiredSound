<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">Log In</h2>

          <%= form_with url: "#", local: true do |f| %>
            <div class="mb-3">
              <%= f.label :username, "Username", class: "form-label fw-bold" %>
              <%= f.text_field :username, class: "form-control", placeholder: "Enter your username" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Password", class: "form-label fw-bold" %>
              <%= f.password_field :password, class: "form-control", placeholder: "Enter your password"%>
            </div>

            <div class="d-grid mt-4 mb-2">
              <%= f.submit "Log In", class: "btn btn-primary" %>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>